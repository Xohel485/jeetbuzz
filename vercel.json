{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "vite build",
  "installCommand": "npm install",
  "framework": null,
  "outputDirectory": ".vercel/output",
  "build": {
    "env": {
      "NITRO_PRESET": "vercel"
    }
  },
  "rewrites": [
    {
      "source": "/__l5e/:path*",
      "destination": "https://project--b6a57b46-03f8-4ad7-95af-1c2e88e2b85f.lovable.app/__l5e/:path*"
    }
  ],
  "headers": [
    {
      "source": "/fonts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/img/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/favicon-(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.(js|mjs|css|woff|woff2|ttf|otf|eot|avif|webp|png|jpg|jpeg|gif|svg|ico)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}